# Core limits
TEXT_EXTRACTION_MAX_FILE_SIZE_MB=50
TEXT_EXTRACTION_MAX_LINES_PER_PAGE=50
TEXT_EXTRACTION_MAX_CHARS_PER_PAGE=3500
TEXT_EXTRACTION_REMOTE_FETCH_TIMEOUT_SEC=20

# Optional OpenAI API key for enrichment
OPENAI_API_KEY=

# Optional Swagger / ReDoc Basic Auth
SWAGGER_USERNAME=
SWAGGER_PASSWORD=

# Optional OpenAI enrichment tuning
TEXT_EXTRACTION_OPENAI_API_BASE=https://api.openai.com/v1
TEXT_EXTRACTION_OPENAI_MODEL=gpt-4.1-mini
TEXT_EXTRACTION_OPENAI_TIMEOUT_SEC=20
TEXT_EXTRACTION_OPENAI_EXCERPT_CHARS=8000

# Note:
# If OPENAI_API_KEY is empty, the service runs without AI enrichment.
# If SWAGGER_USERNAME and SWAGGER_PASSWORD are filled, /docs, /redoc,
# and /openapi.json require Basic Auth.
